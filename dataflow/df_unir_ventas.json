{
	"name": "df_unir_ventas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_sucursal_scz_limpia",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ventas_sucursal_lpz_limpia",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ventas_online_limpia",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ventas_sucursal_scz_limpia_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				},
				{
					"name": "union2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string,",
				"          canal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string,",
				"          canal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          sucursal as string,",
				"          metodo_pago as string,",
				"          estado as string,",
				"          costo_envio as string,",
				"          canal as string,",
				"          cliente as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1, source2 union(byName: true)~> union1",
				"union1, source3 union(byName: true)~> union2",
				"union2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['union_ventas_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}